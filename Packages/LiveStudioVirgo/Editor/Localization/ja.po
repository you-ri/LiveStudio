#: Editor/StudioHomeWindow/StudioHomeWindow.cs:1
msgid "Studio Home"
msgstr "Studio ホーム"

#: Editor/StudioHomeWindow/StudioHomeWindow.cs:2
msgid "Welcome to Virgo Motion Studio Editor"
msgstr "Virgo Motion Studio Editor へようこそ"

#: Editor/StudioHomeWindow/StudioHomeWindow.cs:3
